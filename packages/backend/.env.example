# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/admin_panel
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Test Database Configuration (for running migrations and tests)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=admin_panel_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres

# Migration Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admin_panel
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB Configuration
DYNAMODB_AUDIT_TABLE=audit_logs
DYNAMODB_ENDPOINT=http://localhost:8000

# S3 Configuration
S3_REPORTS_BUCKET=admin-panel-reports-dev
S3_ENDPOINT=

# SQS Configuration
SQS_REPORT_QUEUE_URL=

# SNS Configuration
SNS_NOTIFICATION_TOPIC_ARN=

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=30d

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@admin-panel.com

# Security
BCRYPT_ROUNDS=12
SESSION_TTL=28800

# Monitoring
LOG_LEVEL=info
CLOUDWATCH_LOG_GROUP=/admin-panel/backend
