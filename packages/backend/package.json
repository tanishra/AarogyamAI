{
  "name": "@admin-panel/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/migrations/run-migrations.ts",
    "migrate:up": "tsx src/migrations/run-migrations.ts up",
    "migrate:down": "tsx src/migrations/run-migrations.ts down",
    "migrate:status": "tsx src/migrations/run-migrations.ts status"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1004.0",
    "@aws-sdk/client-dynamodb": "^3.1001.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/client-secrets-manager": "^3.490.0",
    "@aws-sdk/client-sns": "^3.490.0",
    "@aws-sdk/client-sqs": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.1001.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.25.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "fast-check": "^3.15.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
